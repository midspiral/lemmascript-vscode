{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LemmaScript Annotations",
  "scopeName": "lemmascript.injection",
  "injectionSelector": "L:comment.line.double-slash",
  "patterns": [{ "include": "#annotations" }],
  "repository": {
    "annotations": {
      "comment": "One rule per directive so each gets its own scope (keyword.control.lemmascript.<name>) and can be themed independently. The `@` must follow `//` directly. `assert-shaped` is listed before `assert` so the longer keyword wins. Only recognized directives trigger highlighting, so typos and prose stay plain. The expression body is tokenized directly (see #spec) rather than by embedding source.ts.",
      "patterns": [
        { "include": "#dir-requires" },
        { "include": "#dir-ensures" },
        { "include": "#dir-invariant" },
        { "include": "#dir-decreases" },
        { "include": "#dir-declare-type" },
        { "include": "#dir-contract" },
        { "include": "#dir-done_with" },
        { "include": "#dir-backend" },
        { "include": "#dir-extern" },
        { "include": "#dir-verify" },
        { "include": "#dir-ghost" },
        { "include": "#dir-havoc" },
        { "include": "#dir-assume" },
        { "include": "#dir-assert-shaped" },
        { "include": "#dir-assert" },
        { "include": "#dir-autohavoc" },
        { "include": "#dir-safe-slice" },
        { "include": "#dir-pure" },
        { "include": "#dir-type" }
      ]
    },

    "dir-requires":     { "begin": "(?<=//)(@)[ \\t]+(requires)\\b",     "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.requires" } },     "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-ensures":      { "begin": "(?<=//)(@)[ \\t]+(ensures)\\b",      "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.ensures" } },      "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-invariant":    { "begin": "(?<=//)(@)[ \\t]+(invariant)\\b",    "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.invariant" } },    "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-decreases":    { "begin": "(?<=//)(@)[ \\t]+(decreases)\\b",    "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.decreases" } },    "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-declare-type": { "begin": "(?<=//)(@)[ \\t]+(declare-type)\\b", "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.declare-type" } }, "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-contract":     { "comment": "Natural-language statement of intent; the body is prose (provers ignore it), so it is NOT run through #spec — only the keyword is highlighted.", "match": "(?<=//)(@)[ \\t]+(contract)\\b", "captures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.contract" } } },
    "dir-done_with":    { "begin": "(?<=//)(@)[ \\t]+(done_with)\\b",    "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.done_with" } },    "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-backend":      { "begin": "(?<=//)(@)[ \\t]+(backend)\\b",      "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.backend" } },      "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-extern":       { "begin": "(?<=//)(@)[ \\t]+(extern)\\b",       "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.extern" } },       "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-verify":       { "begin": "(?<=//)(@)[ \\t]+(verify)\\b",       "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.verify" } },       "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-ghost":        { "begin": "(?<=//)(@)[ \\t]+(ghost)\\b",        "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.ghost" } },        "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-havoc":        { "begin": "(?<=//)(@)[ \\t]+(havoc)\\b",        "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.havoc" } },        "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-assume":       { "begin": "(?<=//)(@)[ \\t]+(assume)\\b",       "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.assume" } },       "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-assert-shaped":{ "begin": "(?<=//)(@)[ \\t]+(assert-shaped)\\b","beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.assert-shaped" } },"end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-assert":       { "begin": "(?<=//)(@)[ \\t]+(assert)\\b",       "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.assert" } },       "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-autohavoc":    { "begin": "(?<=//)(@)[ \\t]+(autohavoc)\\b",    "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.autohavoc" } },    "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-safe-slice":   { "begin": "(?<=//)(@)[ \\t]+(safe-slice)\\b",   "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.safe-slice" } },   "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-pure":         { "begin": "(?<=//)(@)[ \\t]+(pure)\\b",         "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.pure" } },         "end": "(?=$)", "patterns": [{ "include": "#spec" }] },
    "dir-type":         { "begin": "(?<=//)(@)[ \\t]+(type)\\b",         "beginCaptures": { "1": { "name": "punctuation.definition.annotation.lemmascript" }, "2": { "name": "keyword.control.lemmascript.type" } },         "end": "(?=$)", "patterns": [{ "include": "#spec" }] },

    "spec": {
      "patterns": [
        { "include": "#result" },
        { "include": "#quantifier" },
        { "include": "#constant" },
        { "include": "#spec-type" },
        { "include": "#number" },
        { "include": "#string" },
        { "include": "#implies" },
        { "include": "#operator" }
      ]
    },
    "result": {
      "comment": "The \\result keyword: the return value, usable in `ensures`.",
      "match": "\\\\result\\b",
      "name": "variable.language.result.lemmascript"
    },
    "quantifier": {
      "comment": "Spec quantifiers: forall(k, P), exists(k: nat, P).",
      "match": "\\b(forall|exists)\\b",
      "name": "keyword.other.quantifier.lemmascript"
    },
    "constant": {
      "match": "\\b(true|false|null|undefined)\\b",
      "name": "constant.language.lemmascript"
    },
    "spec-type": {
      "comment": "Type names in `//@ type x nat` overrides and quantifier binders.",
      "match": "\\b(nat|int|real|bool|boolean|string|number)\\b",
      "name": "support.type.lemmascript"
    },
    "number": {
      "match": "\\b(0[xX][0-9a-fA-F]+|[0-9]+(?:\\.[0-9]+)?)n?\\b",
      "name": "constant.numeric.lemmascript"
    },
    "string": {
      "comment": "Backslash escapes (e.g. \\\") are consumed so a `\\\"` does not end the string early.",
      "patterns": [
        { "begin": "\"", "end": "\"", "name": "string.quoted.double.lemmascript", "patterns": [{ "include": "#string-escape" }] },
        { "begin": "'", "end": "'", "name": "string.quoted.single.lemmascript", "patterns": [{ "include": "#string-escape" }] }
      ]
    },
    "string-escape": {
      "match": "\\\\.",
      "name": "constant.character.escape.lemmascript"
    },
    "implies": {
      "comment": "Logical implication / bi-implication. Matched before the generic operator rule so `==>` is not split into `==` and `>`.",
      "match": "<==>|==>|<==",
      "name": "keyword.operator.logical.lemmascript"
    },
    "operator": {
      "match": "===|!==|==|!=|>=|<=|&&|\\|\\||!|<|>|\\+|-|\\*|/|%|\\?|:",
      "name": "keyword.operator.lemmascript"
    }
  }
}
