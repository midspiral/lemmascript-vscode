{
  "name": "lemmascript",
  "private": true,
  "displayName": "LemmaScript for VS Code",
  "description": "Syntax highlighting for LemmaScript contracts in TypeScript — and (later) a viewer for verification results.",
  "icon": "images/icon.png",
  "version": "0.1.0",
  "preview": true,
  "publisher": "midspiral",
  "license": "MIT",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "lemmascript",
    "verification",
    "formal-methods",
    "dafny",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/midspiral/lemmascript-vscode"
  },
  "homepage": "https://lemmascript.com",
  "bugs": {
    "url": "https://github.com/midspiral/lemmascript-vscode/issues"
  },
  "galleryBanner": {
    "color": "#1B2A26",
    "theme": "dark"
  },
  "contributes": {
    "grammars": [
      {
        "scopeName": "lemmascript.injection",
        "path": "./syntaxes/lemmascript.injection.json",
        "injectTo": [
          "source.ts",
          "source.tsx",
          "source.js",
          "source.jsx"
        ]
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "punctuation.definition.annotation.lemmascript",
            "settings": {
              "fontStyle": "bold"
            }
          },
          {
            "scope": "keyword.control.lemmascript",
            "settings": {
              "foreground": "#808080",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "keyword.control.lemmascript.requires",
            "settings": {
              "foreground": "#C08A2E",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "keyword.control.lemmascript.ensures",
            "settings": {
              "foreground": "#1B8A6E",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "keyword.control.lemmascript.contract",
            "settings": {
              "foreground": "#AD3DA4",
              "fontStyle": "bold"
            }
          }
        ]
      }
    }
  },
  "scripts": {
    "fetch-ts-grammar": "node scripts/fetch-ts-grammar.mjs",
    "pretest:grammar": "npm run fetch-ts-grammar",
    "test:grammar": "vscode-tmgrammar-snap -g test/vendor/TypeScript.tmLanguage.json -g syntaxes/lemmascript.injection.json -s source.ts \"test/grammar/*.sample.ts\"",
    "test:grammar:update": "npm run pretest:grammar && vscode-tmgrammar-snap -u -g test/vendor/TypeScript.tmLanguage.json -g syntaxes/lemmascript.injection.json -s source.ts \"test/grammar/*.sample.ts\"",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.0",
    "ovsx": "^1.0.1",
    "vscode-tmgrammar-test": "^0.1.3"
  }
}
